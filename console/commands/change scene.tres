[resource]
script = ExtResource("1_wh7bw")
name = "cs"
description = "Changes the scene to a new one."
detailed_explaination = "Changes the scene to your desired scene. This must be a scene that's in the project and placed in the [color=yellow]res://scenes/[/color] folder. You don't have to put [color=yellow].tscn[/color] after it, because the Console is designed to save time."
function_to_trigger = "change_scene"
